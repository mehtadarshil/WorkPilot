# Copy to .env in this folder (never commit .env):
#   cp .env.example .env

# --- Server ---
PORT=4000
NODE_ENV=development

# Comma-separated browser origins allowed to call the API (omit in local dev for permissive CORS).
# Example: http://localhost:3001,https://app.yourdomain.com
# CORS_ORIGIN=http://localhost:3001

# --- Database (pick ONE style) ---

# Option A: single URL (Railway, Render, Neon, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/workpilot
# For local URL without SSL, disable SSL explicitly:
# DB_SSL=false
# If the host requires SSL but uses a self-signed cert (some clouds):
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Option B: discrete fields (matches default docker-compose Postgres)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=workpilot
DB_USER=workpilot_user
DB_PASSWORD=workpilot_password

# --- Auth (required in production) ---
# Generate a long random string (32+ characters), e.g. openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1d

# --- First super admin (required if NODE_ENV=production and database has no users) ---
# In development, defaults are used if these are unset.
SUPER_ADMIN_EMAIL=superadmin@workpilot.local
SUPER_ADMIN_PASSWORD=superadmin123

# --- Outgoing email (optional) ---
# SMTP is configured per admin in the app: Settings → Email (stored in the database).
# For Gmail/Google Workspace use an app password and typically host smtp.gmail.com, port 587, secure off (STARTTLS).

# Optional: inserted as {{service_reminder_booking_portal_url}} in automated service renewal customer emails.
# WORKPILOT_CUSTOMER_PORTAL_URL=https://bookings.example.com

# --- Email OAuth (Google/Microsoft) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback

# --- File storage (optional overrides; defaults under backend/data/) ---
# CUSTOMER_FILES_DIR=
# CUSTOMER_SITE_REPORT_IMAGES_DIR=
