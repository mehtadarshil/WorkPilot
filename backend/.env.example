# Copy to .env in this folder (never commit .env):
#   cp .env.example .env

# --- Server ---
PORT=4000
NODE_ENV=development

# Comma-separated browser origins allowed to call the API (omit in local dev for permissive CORS).
# Example: http://localhost:3000,https://app.yourdomain.com
# CORS_ORIGIN=http://localhost:3000

# --- Database (pick ONE style) ---

# Option A: single URL (Railway, Render, Neon, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/workpilot
# For local URL without SSL, disable SSL explicitly:
# DB_SSL=false
# If the host requires SSL but uses a self-signed cert (some clouds):
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Option B: discrete fields (matches default docker-compose Postgres)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=workpilot
DB_USER=workpilot_user
DB_PASSWORD=workpilot_password

# --- Auth (required in production) ---
# Generate a long random string (32+ characters), e.g. openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=1d

# --- First super admin (required if NODE_ENV=production and database has no users) ---
# In development, defaults are used if these are unset.
SUPER_ADMIN_EMAIL=superadmin@workpilot.local
SUPER_ADMIN_PASSWORD=superadmin123
