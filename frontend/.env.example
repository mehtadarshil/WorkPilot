# Copy to .env.local in this folder (Next.js reads it automatically; never commit .env.local):
#   cp .env.example .env.local

# Public API base URL (exposed to the browser — do not put server-only secrets here).
# Omit this or use `/api` for local dev: `next dev` rewrites `/api` to the backend (see next.config.ts).
# You must run the backend (e.g. `cd backend && npm run dev`, default port 4000).
NEXT_PUBLIC_API_BASE_URL=https://api.work-pilot.co/api

# Optional: if the API is not on 4000, set the origin used by dev rewrites (no trailing slash).
# BACKEND_DEV_ORIGIN=http://127.0.0.1:4000
